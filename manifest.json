{
  "manifest_version": 3,
  "name": "Task Tracker",
  "description": "Track and manage tasks from your browser",
  "version": "1.1",
  "background": { "service_worker": "background.js", "type": "module" },
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/list.png",
      "48": "icons/list.png",
      "128": "icons/list.png"
    }
  },
  "icons": {
    "16": "icons/list.png",
    "48": "icons/list.png",
    "128": "icons/list.png"
  }
}
